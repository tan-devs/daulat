{
	"name": "daulat",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"clense": "pnpm format && pnpm lint && pnpm check",
		"dev:client": "vite dev --host",
		"dev:frontend": "vite dev --host 127.0.0.1 --port 5173",
		"dev:server": "pnpm dlx convex dev",
		"dev": "concurrently --kill-others --prefix-colors red,yellow --names \"svelte,convex\" \"pnpm dev:client\" \"pnpm dev:server\"",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@clerk/backend": "^3.2.13",
		"@eslint/compat": "latest",
		"@eslint/js": "latest",
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.8.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"bits-ui": "^2.17.3",
		"clsx": "^2.1.1",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@fontsource-variable/martian-mono": "^5.2.7",
		"@toolwind/corner-shape": "0.0.8-3",
		"concurrently": "^9.2.1",
		"convex": "^1.35.1",
		"convex-svelte": "^0.0.12",
		"mode-watcher": "^1.1.0",
		"svelte-clerk": "^1.1.3",
		"svix": "^1.90.0"
	}
}
